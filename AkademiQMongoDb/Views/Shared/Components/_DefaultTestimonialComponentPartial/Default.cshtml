@model List<AkademiQMongoDb.Dtos.TestimonialDto.ResultTestimonialDto>

<div id="reviews" class="testimonials-color">
    <div class="container">
        <div class="about-inline text-center">
            <h3>Referanslar</h3>
        </div>
        <div class="row">
            <div class="col-md-12 text-center">
                <div class="quote2 testimonial-slider">
                    @foreach (var item in Model)
                    {
                        <div class="testimonial-item">
                            <div class="testimonial-content">
                                <img src="@item.ImageUrl" alt="@item.NameSurname" class="img-circle" />
                                <p class="description">"@item.Description"</p>
                                <div class="author-info">
                                    <span class="author">@item.NameSurname</span>
                                    <span class="position">@item.Pozition</span>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
        <div class="space100"></div>
    </div>
</div>

<style>
    .testimonial-item {
        padding: 20px;
        outline: none;
    }

        .testimonial-item img {
            width: 80px;
            height: 80px;
            border-radius: 50%;
            margin: 0 auto 15px;
            border: 3px solid #fff;
            box-shadow: 0 4px 8px rgba(0,0,0,0.1);
        }

    .testimonial-content p {
        font-style: italic;
        font-size: 16px;
        color: #555;
        line-height: 1.6;
    }

    .author-info .author {
        display: block;
        font-weight: bold;
        margin-top: 10px;
        color: #333;
    }

    .author-info .position {
        font-size: 13px;
        color: #888;
    }
</style>

<link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/npm/slick-carousel@1.8.1/slick/slick.css" />
<script type="text/javascript" src="https://cdn.jsdelivr.net/npm/slick-carousel@1.8.1/slick/slick.min.js"></script>

<script>
    $(document).ready(function(){
        $('.testimonial-slider').slick({
            dots: true,          // Alt kısımda noktalar gösterilsin mi?
            infinite: true,      // Sonsuz döngü
            speed: 500,          // Geçiş hızı
            slidesToShow: 1,     // Aynı anda kaç yorum görünsün?
            autoplay: true,      // Otomatik kaydır
            autoplaySpeed: 3000, // 3 saniyede bir kaydır
            arrows: false,       // Yan okları gizle (isteğe bağlı)
            adaptiveHeight: true
        });
    });
</script>