@model AkademiQMongoDb.Dtos.StoryVideoDto.ResultVideoDto

@if (Model != null)
{
    @* Ana Konteynır (Kısa boylu) *@
    <div class="video-action-wrapper">

        @* Arka Plan Katmanı (Bulanık ve Karanlık) *@
        <div class="video-background-layer" style="background-image: url('@Model.ImageUrl');"></div>

        @* İçerik Kutusu (Yazıları öne çıkaran katman) *@
        <div class="video-content-box">
            <h1>@Model.Title</h1>
            <p>@Model.Description</p>

            <a href="@Model.VideoUrl" class="swipebox-video">
                <div class="intro-video-pop">
                    <i class="fa fa-play"></i>
                </div>
                <small class="d-block text-white mt-2">Tanıtım Videosunu İzleyin</small>
            </a>
        </div>
    </div>
}

<style>
    /* Video Bölümü Genel Konteynırı */
    .video-action-wrapper {
        position: relative;
        width: 100%; /* Genişlik aynı kalıyor */
        height: 400px; /* BOYUNU KISALTTIK (İstediğiniz değere göre değiştirebilirsiniz) */
        overflow: hidden; /* Bulanıklığın taşmasını engellemek için */
        display: flex;
        align-items: center; /* İçeriği dikeyde ortalar */
        justify-content: center; /* İçeriği yatayda ortalar */
        background-color: #000; /* Görsel yüklenmezse arkası siyah olsun */
    }

    /* Arka Plan Görseli (Bulanıklık ve Karanlık Katman) */
    .video-background-layer {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        /* 1. İstek: BULANIKLIK */
        filter: blur(8px); /* Bulanıklık şiddeti (arttırıp azaltabilirsiniz) */
        /* Bulanıklık kenarlarda beyazlık yapmasın diye görseli hafifçe büyütüyoruz */
        transform: scale(1.1);
        z-index: 1;
    }

        /* 2. İstek: ÜZERİNDEKİ KARANLIK ARTIRMA */
        .video-background-layer::after {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.75); /* %75 SİYAH KATMAN (Daha karanlık olması için arttırdık) */
        }

    /* İçerik Kutusu (Yazıları öne çıkarmak için) */
    .video-content-box {
        position: relative;
        z-index: 2; /* Arka planın üzerinde kalması için */
        color: #ffffff;
        text-align: center;
        max-width: 700px; /* Yazıların çok yayılmaması için */
        padding: 0 15px;
    }

        /* Yazı Hiyerarşisi */
        .video-content-box h1 {
            font-family: 'Playfair Display', serif; /* Restoran konseptine uygun font */
            font-size: 3rem;
            font-weight: 700;
            margin-bottom: 15px;
            color: #fff;
            text-shadow: 0 2px 10px rgba(0,0,0,0.5); /* Yazıya hafif gölge (okunabilirliği artırır) */
        }

        .video-content-box p {
            font-size: 1.1rem;
            color: #e0e0e0;
            line-height: 1.6;
            margin-bottom: 30px;
        }

    /* Oynat Butonu (Pulse Animasyonu ile) */
    .intro-video-pop {
        display: inline-block;
        width: 80px;
        height: 80px;
        line-height: 80px;
        border-radius: 50%;
        background: #ff5722; /* Restoran rengi */
        color: #fff;
        font-size: 24px;
        transition: all 0.3s ease;
        box-shadow: 0 0 0 0 rgba(255, 87, 34, 0.5);
        animation: pulse-border 1.5s infinite;
    }

        .intro-video-pop:hover {
            transform: scale(1.1);
            background: #fff;
            color: #ff5722;
        }

    /* Butonun etrafındaki dalgalanma efekti */
    @@keyframes pulse-border {
        0% {
            box-shadow: 0 0 0 0 rgba(255, 87, 34, 0.7);
        }

        100% {
            box-shadow: 0 0 0 20px rgba(255, 87, 34, 0);
        }
    }
</style>