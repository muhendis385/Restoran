@model List<AkademiQMongoDb.Dtos.ProductDto.ResultProductDto>
@{
    ViewData["Title"] = "Ürün Listesi";
    Layout = "~/Views/Admin/_AdminLayout.cshtml";
    int i = 0;
}

<style>
    /* Tablo Konteynırı */
    .product-card {
        border: none;
        border-radius: 15px;
        background: #fff;
    }

    /* Ürün Görseli */
    .product-img {
        width: 55px;
        height: 55px;
        object-fit: cover;
        border-radius: 10px;
        border: 1px solid #eee;
    }

    /* Fiyat Etiketleri */
    .price-main {
        font-weight: 700;
        color: #2d3748;
        font-size: 1rem;
    }

    .price-old {
        text-decoration: line-through;
        color: #a0aec0;
        font-size: 0.8rem;
    }

    /* Badge (Süre) */
    .time-badge {
        background: #f1f5f9;
        color: #475569;
        padding: 4px 10px;
        border-radius: 6px;
        font-weight: 600;
        font-size: 0.8rem;
        display: inline-flex;
        align-items: center;
    }

    /* Modern Butonlar (Metinli) */
    .btn-admin-action {
        padding: 6px 14px;
        border-radius: 8px;
        font-weight: 600;
        font-size: 0.85rem;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        transition: all 0.2s ease;
        border: none;
    }

    .btn-update-modern {
        background-color: #fff9db;
        color: #856404;
    }

        .btn-update-modern:hover {
            background-color: #ffec99;
            color: #856404;
            text-decoration: none;
        }

    .btn-delete-modern {
        background-color: #fff5f5;
        color: #c53030;
    }

        .btn-delete-modern:hover {
            background-color: #feb2b2;
            color: #c53030;
        }

    .table-admin thead th {
        border-top: none;
        text-transform: uppercase;
        font-size: 0.75rem;
        letter-spacing: 0.5px;
        font-weight: 700;
        color: #94a3b8;
    }
</style>

<div class="row">
    <div class="col-lg-12 grid-margin stretch-card">
        <div class="card product-card shadow-sm">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div>
                        <h4 class="card-title mb-1" style="font-weight: 800;">Ürün Portföyü</h4>
                        <p class="text-muted small mb-0">Toplam <b>@Model.Count</b> adet kayıtlı ürün.</p>
                    </div>
                    <a href="/Product/CreateProduct/" class="btn btn-primary btn-rounded px-4 shadow-sm">
                        <i class="mdi mdi-plus-circle-outline mr-1"></i> Yeni Ürün Ekle
                    </a>
                </div>

                <div class="table-responsive">
                    <table class="table table-admin align-middle">
                        <thead>
                            <tr>
                                <th class="text-center">#</th>
                                <th>Ürün Bilgisi</th>
                                <th class="text-center">Üretim Süresi</th>
                                <th class="text-center">Fiyatlandırma</th>
                                <th class="text-center">İşlemler</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                i++;
                                <tr>
                                    <td class="text-center font-weight-bold text-muted">@i</td>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <img src="@item.ImageUrl" alt="@item.ProductName" class="product-img mr-3" />
                                            <div>
                                                <span class="d-block font-weight-bold text-dark">@item.ProductName</span>
                                                <small class="text-muted">#@item.ProductId.ToString().Substring(0, 5)</small>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="text-center">
                                        <div class="time-badge">
                                            <i class="mdi mdi-clock-fast mr-1"></i>
                                            @item.TotalTime dk
                                        </div>
                                    </td>
                                    <td class="text-center">
                                        @if (item.OldPrice > 0)
                                        {
                                            <div class="price-old">@item.OldPrice.ToString("C2")</div>
                                        }
                                        <div class="price-main">@item.Price.ToString("C2")</div>
                                    </td>
                                    <td class="text-center">
                                        <div class="d-flex justify-content-center">
                                            <a href="/Product/UpdateProduct/@item.ProductId" class="btn-admin-action btn-update-modern mr-2">
                                                <i class="mdi mdi-pencil"></i> Güncelle
                                            </a>
                                            <button type="button" onclick="deleteConfirm('@item.ProductId')" class="btn-admin-action btn-delete-modern">
                                                <i class="mdi mdi-trash-can-outline"></i> Sil
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    function deleteConfirm(id) {
        Swal.fire({
            title: 'Ürünü Sil?',
            text: "Bu ürünü menüden kaldırmak istediğinize emin misiniz?",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#c53030',
            cancelButtonColor: '#718096',
            confirmButtonText: 'Evet, Sil',
            cancelButtonText: 'Vazgeç',
            reverseButtons: true
        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = "/Product/DeleteProduct/" + id;
            }
        })
    }
</script>