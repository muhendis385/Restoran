@model AkademiQMongoDb.Dtos.ProductDto.CreateProductDto

@{
    ViewData["Title"] = "Yeni Ürün Ekle";
    Layout = "~/Views/Admin/_AdminLayout.cshtml";
}

<style>
    /* Modern Kart Tasarımı */
    .create-card {
        border: none;
        border-radius: 20px;
        background: #fff;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05) !important;
    }

    /* Görsel Önizleme Alanı */
    .image-preview-wrapper {
        position: relative;
        width: 100%;
        height: 250px;
        background: #f8f9fa;
        border: 2px dashed #dee2e6;
        border-radius: 15px;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        transition: all 0.3s;
    }

        .image-preview-wrapper img {
            max-width: 100%;
            max-height: 100%;
            object-fit: contain;
        }

    /* Input Odak Efektleri */
    .form-control {
        border-radius: 10px;
        padding: 12px 15px;
        border: 1.5px solid #f1f1f1;
        transition: all 0.3s;
    }

        .form-control:focus {
            border-color: #4B49AC;
            box-shadow: 0 0 0 0.2rem rgba(75, 73, 172, 0.1);
            background-color: #fff;
        }

    /* Bölüm Başlıkları */
    .section-title {
        font-size: 1.1rem;
        font-weight: 700;
        color: #333;
        margin-bottom: 20px;
        border-left: 4px solid #4B49AC;
        padding-left: 15px;
    }

    .btn-modern {
        border-radius: 12px;
        padding: 12px 25px;
        font-weight: 600;
        transition: all 0.3s;
    }
</style>

<div class="row">
    <div class="col-lg-12">
        <div class="card create-card">
            <div class="card-body p-4 p-md-5">
                <!-- Başlık Alanı -->
                <div class="d-flex align-items-center mb-5">
                    <div class="bg-primary-lighter p-3 rounded-circle mr-3">
                        <i class="mdi mdi-plus-box text-primary h3 mb-0"></i>
                    </div>
                    <div>
                        <h3 class="font-weight-bold mb-1 text-dark">Yeni Ürün Tanımlama</h3>
                        <p class="text-muted small mb-0">Menünüze yeni bir lezzet katmak için bilgileri doldurun.</p>
                    </div>
                </div>

                <form method="post" class="forms-sample">
                    <div class="row">
                        <!-- Sol Kolon: Form Bilgileri -->
                        <div class="col-md-8">
                            <h5 class="section-title">Ürün Detayları</h5>

                            <div class="form-group mb-4">
                                <label class="font-weight-bold">Ürün Adı</label>
                                <div class="input-group">
                                    <div class="input-group-prepend">
                                        <span class="input-group-text bg-white border-right-0"><i class="mdi mdi-tag-outline text-primary"></i></span>
                                    </div>
                                    <input type="text" class="form-control border-left-0" asp-for="ProductName" placeholder="Örn: Gurme Burger" required>
                                </div>
                            </div>

                            <div class="row">
                                <div class="form-group col-md-6 mb-4">
                                    <label class="font-weight-bold">Hazırlanma Süresi</label>
                                    <div class="input-group">
                                        <div class="input-group-prepend">
                                            <span class="input-group-text bg-white border-right-0"><i class="mdi mdi-clock-outline"></i></span>
                                        </div>
                                        <input type="number" class="form-control border-left-0" asp-for="TotalTime" placeholder="Dakika cinsinden">
                                    </div>
                                </div>
                                <div class="form-group col-md-6 mb-4">
                                    <label class="font-weight-bold text-primary">Görsel URL</label>
                                    <input type="text" id="imageUrlInput" class="form-control" asp-for="ImageUrl" placeholder="https://...">
                                </div>
                            </div>

                            <h5 class="section-title mt-4">Fiyatlandırma</h5>
                            <div class="row">
                                <div class="form-group col-md-6 mb-4">
                                    <label class="font-weight-bold text-success">Satış Fiyatı</label>
                                    <div class="input-group">
                                        <div class="input-group-prepend">
                                            <span class="input-group-text bg-success text-white border-0">₺</span>
                                        </div>
                                        <input type="text" class="form-control font-weight-bold" asp-for="Price" placeholder="0.00">
                                    </div>
                                </div>
                                <div class="form-group col-md-6 mb-4">
                                    <label class="font-weight-bold text-danger">Eski Fiyat (Kampanya İçin)</label>
                                    <div class="input-group">
                                        <div class="input-group-prepend">
                                            <span class="input-group-text bg-light text-danger border-0">₺</span>
                                        </div>
                                        <input type="text" class="form-control" asp-for="OldPrice" placeholder="0.00">
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Sağ Kolon: Canlı Görsel Önizleme -->
                        <div class="col-md-4">
                            <h5 class="section-title">Görsel Önizleme</h5>
                            <div class="image-preview-wrapper shadow-sm mb-3">
                                <img src="/admintemplate/images/no-image.png" id="imgPreview" alt="Önizleme Bekleniyor" />
                            </div>
                            <p class="text-muted text-center small">Geçerli bir görsel URL'si girdiğinizde burada görünecektir.</p>
                        </div>
                    </div>

                    <!-- Butonlar -->
                    <div class="mt-5 pt-4 border-top d-flex justify-content-end">
                        <a href="/Product/ProductList" class="btn btn-light btn-modern mr-3">
                            <i class="mdi mdi-close-circle-outline mr-1"></i> Vazgeç
                        </a>
                        <button type="submit" class="btn btn-primary btn-modern px-5 shadow-sm">
                            <i class="mdi mdi-check-circle-outline mr-1"></i> Ürünü Sisteme Kaydet
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    // Canlı Önizleme Scripti
    const urlInput = document.getElementById('imageUrlInput');
    const imgPreview = document.getElementById('imgPreview');

    urlInput.addEventListener('input', function() {
        if(this.value.trim() !== "") {
            imgPreview.src = this.value;
        } else {
            imgPreview.src = '/admintemplate/images/no-image.png';
        }
    });

    // Görsel yüklenirken hata oluşursa varsayılan resmi göster
    imgPreview.onerror = function() {
        this.src = '/admintemplate/images/no-image.png';
    };
</script>