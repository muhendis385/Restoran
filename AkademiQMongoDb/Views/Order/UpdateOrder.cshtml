@model AkademiQMongoDb.Dtos.OrderDto.GetByIdOrderDto
@{
    ViewData["Title"] = "Sipariş Güncelle";
    Layout = "~/Views/Admin/_AdminLayout.cshtml";
}

<div class="col-12 grid-margin stretch-card">
    <div class="card shadow-sm border-0">
        <div class="card-body">
            <h4 class="card-title">Sipariş Detayları / Güncelleme</h4>
            <p class="card-description text-muted">Müşteri ve ürün bilgilerini buradan yönetebilirsiniz.</p>
            <hr />
            <form class="forms-sample" method="post">
                <input type="hidden" asp-for="OrderId" />
                <input type="hidden" asp-for="OrderDate" />

                <div class="row">
                    <div class="form-group col-md-6">
                        <label>Müşteri Adı</label>
                        <input type="text" asp-for="CustomerName" class="form-control" />
                    </div>
                    <div class="form-group col-md-6">
                        <label>Müşteri E-Posta</label>
                        <input type="email" asp-for="CustomerEmail" class="form-control" />
                    </div>
                </div>

                <div class="row">
                    <div class="form-group col-md-6">
                        <label>Ürün Adı</label>
                        <input type="text" asp-for="ProductName" class="form-control" readonly />
                    </div>
                    <div class="form-group col-md-6">
                        <label>Fiyat (TL)</label>
                        <input type="text" asp-for="Price" class="form-control" readonly/>
                    </div>
                </div>

                <div class="form-group">
                    <label>Teslimat Adresi</label>
                    <textarea asp-for="Address" class="form-control" rows="4"></textarea>
                </div>

                <div class="form-group">
                    <div class="form-check form-check-flat form-check-primary">
                        <label class="form-check-label">
                            <input type="checkbox" asp-for="IsCompleted" class="form-check-input">
                            Teslim Edildi / Tamamlandı Olarak İşaretle
                            <i class="input-helper"></i>
                        </label>
                    </div>
                </div>

                <button type="submit" class="btn btn-primary mr-2">Değişiklikleri Kaydet</button>
                <a href="/Order/OrderList" class="btn btn-light">Listeye Dön</a>
            </form>
        </div>
    </div>
</div>