@model List<AkademiQMongoDb.Dtos.AboutSection2.ResultAbout2Dto>
@{
    ViewData["Title"] = "Hakkımızda (Bölüm 2) Yönetimi";
    Layout = "~/Views/Admin/_AdminLayout.cshtml";
}

<style>
    /* Ana Kart Tasarımı */
    .about2-card {
        border: none;
        border-radius: 20px;
        overflow: hidden;
        background: #fff;
        transition: all 0.3s ease;
    }

    /* Görsel Alanı */
    .about2-img-wrapper {
        position: relative;
        width: 100%;
        height: 300px;
        border-radius: 15px;
        overflow: hidden;
        box-shadow: 0 10px 20px rgba(0,0,0,0.1);
    }

        .about2-img-wrapper img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    /* İçerik Detayları */
    .about2-badge {
        background: #eef2ff;
        color: #4B49AC;
        padding: 6px 15px;
        border-radius: 50px;
        font-size: 11px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .about2-title {
        font-size: 1.75rem;
        font-weight: 800;
        color: #2d3748;
        margin-top: 10px;
    }

    /* İkonlu Maddeler */
    .feature-list {
        margin: 20px 0;
        padding-left: 0;
    }

    .feature-item {
        display: flex;
        align-items: center;
        margin-bottom: 12px;
        font-size: 1rem;
        color: #4a5568;
    }

        .feature-item i {
            background: #f0fdf4;
            color: #10b981;
            width: 30px;
            height: 30px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 50%;
            margin-right: 12px;
            font-size: 14px;
            box-shadow: 0 2px 5px rgba(16, 185, 129, 0.1);
        }

    /* İşlem Butonları */
    .btn-group-custom {
        display: flex;
        gap: 10px;
        margin-top: 25px;
    }

    .btn-action-modern {
        padding: 10px 20px;
        border-radius: 12px;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: all 0.2s;
    }

    .btn-update {
        background: #fffbeb;
        color: #d97706;
        border: 1px solid #fde68a;
    }

        .btn-update:hover {
            background: #d97706;
            color: #fff;
        }

    .btn-delete {
        background: #fef2f2;
        color: #dc2626;
        border: 1px solid #fecaca;
    }

        .btn-delete:hover {
            background: #dc2626;
            color: #fff;
        }
</style>

<div class="row">
    <div class="col-12 grid-margin">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h3 class="font-weight-bold mb-1">Hakkımızda (Bölüm 2)</h3>
                <p class="text-muted mb-0">Özellikler ve maddeli içeriklerin yönetimi</p>
            </div>
            <a href="/About2/CreateAbout2" class="btn btn-primary btn-rounded shadow-sm">
                <i class="mdi mdi-plus mr-1"></i> Yeni Madde Ekle
            </a>
        </div>

        @if (Model == null || !Model.Any())
        {
            <div class="text-center py-5 bg-light rounded-xl border-dashed" style="border: 2px dashed #cbd5e0; border-radius: 20px;">
                <i class="mdi mdi-format-list-checks text-muted" style="font-size: 3.5rem;"></i>
                <h4 class="mt-3">İçerik Listeniz Boş</h4>
                <p class="text-muted">Hakkımızda sayfasının ikinci bölümü için henüz bir madde grubu oluşturmadınız.</p>
            </div>
        }
        else
        {
            @foreach (var item in Model)
            {
                <div class="card about2-card shadow-sm mb-4">
                    <div class="card-body">
                        <div class="row align-items-center">
                            <!-- Sol: Görsel -->
                            <div class="col-md-5">
                                <div class="about2-img-wrapper">
                                    <img src="@item.ImageUrl" alt="About Section Image">
                                </div>
                            </div>

                            <!-- Sağ: Detaylar -->
                            <div class="col-md-7">
                                <div class="p-3">
                                    <span class="about2-badge">Maddeli Bölüm İçeriği</span>
                                    <h2 class="about2-title">@item.Title</h2>

                                    <div class="feature-list">
                                        <div class="feature-item">
                                            <i class="mdi mdi-check"></i> @item.Item1
                                        </div>
                                        <div class="feature-item">
                                            <i class="mdi mdi-check"></i> @item.Item2
                                        </div>
                                        @if (!string.IsNullOrEmpty(item.Item3))
                                        {
                                            <div class="feature-item">
                                                <i class="mdi mdi-check"></i> @item.Item3
                                            </div>
                                        }
                                    </div>

                                    <div class="btn-group-custom">
                                        <a href="/About2/UpdateAbout2/@item.AboutSection2Id" class="btn-action-modern btn-update text-decoration-none">
                                            <i class="mdi mdi-pencil-outline"></i> Düzenle
                                        </a>
                                        <button onclick="deleteAbout2('@item.AboutSection2Id')" class="btn-action-modern btn-delete border-0">
                                            <i class="mdi mdi-trash-can-outline"></i> Sil
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    function deleteAbout2(id) {
        Swal.fire({
            title: 'Silmek istediğinize emin misiniz?',
            text: "Bu içerik grubu web sitesinden kaldırılacaktır!",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#dc2626',
            cancelButtonColor: '#6b7280',
            confirmButtonText: 'Evet, Sil',
            cancelButtonText: 'Vazgeç',
            reverseButtons: true
        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = "/About2/DeleteAbout2/" + id;
            }
        });
    }
</script>