@model AkademiQMongoDb.Dtos.ProductDto.ResultProductDto
@{
    ViewData["Title"] = "Dashboard Özet";
    Layout = "~/Views/Admin/_AdminLayout.cshtml";
}

<div class="row">

    <div class="col-md-8 grid-margin stretch-card">
        <div class="card shadow-sm border-0" style="border-radius: 15px;">
            <div class="card-body d-flex align-items-center">
                <img src="@Model.ImageUrl" class="img-lg rounded shadow-sm" style="width: 100px; height:100px; object-fit:cover;">
                <div class="ml-4">
                    <h5 class="text-muted mb-1">Son Eklenen Ürün</h5>
                    <h3 class="text-dark font-weight-bold">@Model.ProductName</h3>
                    <h4 class="text-primary">@Model.Price.ToString("C2")</h4>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-6 grid-margin stretch-card">
        <div class="card shadow-sm" style="border-radius:15px;">
            <div class="card-body">
                <h4 class="card-title">Son 5 Sipariş</h4>
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead class="bg-light">
                            <tr>
                                <th>Müşteri</th>
                                <th>Tutar</th>
                                <th>Durum</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var order in ViewBag.Last5Orders)
                            {
                                <tr>
                                    <td>@order.CustomerName</td>
                                    <td class="font-weight-bold">@order.Price.ToString("C2")</td>
                                    <td><span class="badge @(order.IsCompleted ? "badge-success" : "badge-warning")">@(order.IsCompleted ? "Tamam" : "Bekliyor")</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-6 grid-margin stretch-card">
        <div class="card shadow-sm" style="border-radius:15px;">
            <div class="card-body">
                <h4 class="card-title">Yeni Aboneler</h4>
                <ul class="list-unstyled">
                    @foreach (var sub in ViewBag.Last5Subscribers)
                    {
                        <li class="p-2 border-bottom d-flex justify-content-between align-items-center">
                            <span><i class="mdi mdi-email-outline mr-2 text-info"></i> @sub.Email</span>
                            <small class="text-muted">@sub.SubscriptionDate.ToString("dd.MM.yyyy")</small>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-lg-12 grid-margin stretch-card">
        <div class="card shadow-sm" style="border-radius:15px;">
            <div class="card-body">
                <h4 class="card-title text-center">Müşteri Yorumları (Son 5)</h4>
                <div class="row">
                    @foreach (var item in ViewBag.Last5Testimonials)
                    {
                        <div class="col-md-4 mb-3">
                            <div class="p-3 border rounded h-100 bg-light">
                                <h6 class="font-weight-bold">@item.NameSurname</h6>
                                <p class="small text-muted italic">"@item.Description"</p>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>