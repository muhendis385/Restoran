@model List<AkademiQMongoDb.Dtos.SubscribeDto.ResultSubscriberDto>
@{
    ViewData["Title"] = "Abone Listesi";
    Layout = "~/Views/Admin/_AdminLayout.cshtml";
}

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<div class="col-lg-12 grid-margin stretch-card">
    <div class="card shadow-sm border-0" style="border-radius: 15px;">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h4 class="card-title mb-0">Bülten Aboneleri</h4>
                <span class="badge badge-inverse-primary px-3 py-2">Toplam @Model.Count Kayıt</span>
            </div>

            <div class="table-responsive">
                <table class="table table-hover">
                    <thead class="bg-light">
                        <tr>
                            <th>#</th>
                            <th>E-Posta Adresi</th>
                            <th>Kayıt Tarihi</th>
                            <th class="text-center">Durum</th>
                            <th class="text-center">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            int count = 0;
                        }
                        @foreach (var item in Model)
                        {
                            count++;
                            <tr>
                                <td>@count</td>
                                <td class="font-weight-bold text-dark">@item.Email</td>
                                <td>
                                    <i class="mdi mdi-calendar-check mr-1 text-primary"></i>
                                    @item.SubscriptionDate.ToString("dd.MM.yyyy HH:mm")
                                </td>
                                <td class="text-center">
                                    <span class="badge badge-success">Aktif</span>
                                </td>
                                <td class="text-center">
                                    <button onclick="removeSubscriber('@item.SubscribeId')"
                                            class="btn btn-inverse-danger btn-sm d-inline-flex align-items-center px-3"
                                            style="border-radius: 8px; font-weight: 600;">
                                        <i class="mdi mdi-delete-sweep mr-1"></i> Listeden Çıkar
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<script>
    function removeSubscriber(id) {
        Swal.fire({
            title: 'Aboneyi silmek istiyor musunuz?',
            text: "Bu işlem geri alınamaz!",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#d33',
            cancelButtonColor: '#6c757d',
            confirmButtonText: 'Evet, Sil!',
            cancelButtonText: 'Vazgeç'
        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = "/Subscriber/DeleteSubscriber?id=" + id;
            }
        })
    }
</script>