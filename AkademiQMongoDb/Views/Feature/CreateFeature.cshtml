@model AkademiQMongoDb.Dtos.FeatureDto.CreateFeatureDto
@{
    ViewData["Title"] = "Yeni Öne Çıkan İçerik";
    Layout = "~/Views/Admin/_AdminLayout.cshtml";
}

<div class="col-12 grid-margin stretch-card">
    <div class="card shadow-sm border-0">
        <div class="card-body">
            <div class="d-flex align-items-center mb-4">
                <i class="mdi mdi-star-circle text-primary h3 mr-2"></i>
                <h4 class="card-title mb-0">Ana Sayfa Kapak İçeriği Oluştur</h4>
            </div>

            <p class="card-description text-muted">
                Bu alana ekleyeceğiniz bilgiler, web sitenizin en üst kısmında (Hero Section) görünecektir.
                Etkileyici bir başlık ve yüksek çözünürlüklü bir görsel kullanmanızı öneririz.
            </p>
            <hr />

            <form method="post" class="forms-sample mt-4">
                <div class="row">
                    <div class="form-group col-12">
                        <label class="font-weight-bold">Ana Başlık (Title)</label>
                        <div class="input-group">
                            <div class="input-group-prepend">
                                <span class="input-group-text bg-primary text-white"><i class="mdi mdi-format-title"></i></span>
                            </div>
                            <input type="text" class="form-control" asp-for="Title" placeholder="Örn: En Lezzetli Burgerler Burada!" required>
                        </div>
                        <small class="text-muted">Kısa ve vurucu bir başlık seçin.</small>
                    </div>

                    <div class="form-group col-12">
                        <label class="font-weight-bold">Alt Açıklama (Description)</label>
                        <textarea class="form-control" asp-for="Description" rows="4" placeholder="Ürünleriniz veya kampanyanız hakkında kısa bir bilgi yazın..."></textarea>
                    </div>

                    <div class="form-group col-md-12">
                        <label class="font-weight-bold text-info">Kapak Görseli Linki (ImageUrl)</label>
                        <div class="input-group">
                            <div class="input-group-prepend">
                                <span class="input-group-text"><i class="mdi mdi-image-area"></i></span>
                            </div>
                            <input type="text" id="imageUrlInput" class="form-control" asp-for="ImageUrl" placeholder="https://resim-linkiniz.com/kapak.jpg">
                        </div>
                    </div>
                </div>

                <div class="form-group mt-2" id="previewContainer" style="display:none;">
                    <label class="font-weight-bold text-muted">Görsel Önizleme</label>
                    <div class="border rounded p-2 text-center bg-light">
                        <img src="" id="imgPreview" style="max-width: 100%; height: 200px; object-fit: cover; border-radius: 10px;" />
                    </div>
                </div>

                <div class="mt-4 border-top pt-3">
                    <button type="submit" class="btn btn-primary btn-icon-text mr-2 shadow-sm">
                        <i class="mdi mdi-content-save btn-icon-prepend"></i> İçeriği Yayınla
                    </button>
                    <a href="/Feature/FeatureList" class="btn btn-light btn-icon-text border">
                        <i class="mdi mdi-arrow-left btn-icon-prepend"></i> Listeye Dön
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

