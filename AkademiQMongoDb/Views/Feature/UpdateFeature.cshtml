@model AkademiQMongoDb.Dtos.FeatureDto.GetFeatureByIdDto
@{
    ViewData["Title"] = "Öne Çıkan İçeriği Güncelle";
    Layout = "~/Views/Admin/_AdminLayout.cshtml";
}

<div class="col-12 grid-margin stretch-card">
    <div class="card shadow-sm border-0">
        <div class="card-body">
            <div class="d-flex align-items-center mb-4">
                <i class="mdi mdi-refresh text-warning h3 mr-2"></i>
                <h4 class="card-title mb-0">Öne Çıkan İçeriği Düzenle</h4>
            </div>

            <p class="card-description text-muted">
                Mevcut kapak bilgilerini buradan güncelleyebilirsiniz. Değişiklikler kaydedildikten sonra ana sayfada anında yansıtılacaktır.
            </p>
            <hr />

            <form method="post" class="forms-sample mt-4">
                @* ID alanını sunucuya göndermek için gizli (hidden) olarak tutuyoruz *@
                <input type="hidden" asp-for="FeatureId" />

                <div class="row">
                    <div class="form-group col-12">
                        <label class="font-weight-bold">Ana Başlık (Title)</label>
                        <div class="input-group">
                            <div class="input-group-prepend">
                                <span class="input-group-text bg-warning text-white"><i class="mdi mdi-format-title"></i></span>
                            </div>
                            <input type="text" class="form-control" asp-for="Title" placeholder="Başlık giriniz..." required>
                        </div>
                    </div>

                    <div class="form-group col-12">
                        <label class="font-weight-bold">Alt Açıklama (Description)</label>
                        <textarea class="form-control" asp-for="Description" rows="4" placeholder="Açıklama giriniz..."></textarea>
                    </div>

                    <div class="form-group col-md-12">
                        <label class="font-weight-bold text-info">Kapak Görseli Linki (ImageUrl)</label>
                        <div class="input-group">
                            <div class="input-group-prepend">
                                <span class="input-group-text"><i class="mdi mdi-image-area"></i></span>
                            </div>
                            <input type="text" id="imageUrlInput" class="form-control" asp-for="ImageUrl" placeholder="https://resim-linkiniz.com/kapak.jpg">
                        </div>
                    </div>
                </div>

                <div class="form-group mt-2" id="previewContainer">
                    <label class="font-weight-bold text-muted">Mevcut / Yeni Görsel Önizleme</label>
                    <div class="border rounded p-2 text-center bg-light shadow-sm" style="max-width: 400px;">
                        <img src="@Model.ImageUrl" id="imgPreview" style="max-width: 100%; height: auto; max-height: 250px; object-fit: cover; border-radius: 10px;" />
                    </div>
                </div>

                <div class="mt-4 border-top pt-3">
                    <button type="submit" class="btn btn-warning btn-icon-text mr-2 shadow-sm text-white">
                        <i class="mdi mdi-check-all btn-icon-prepend"></i> Değişiklikleri Kaydet
                    </button>
                    <a href="/Feature/FeatureList" class="btn btn-light btn-icon-text border">
                        <i class="mdi mdi-arrow-left btn-icon-prepend"></i> Vazgeç
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

