@model List<AkademiQMongoDb.Dtos.SSSDto.ResultSSSDto>
@{
    ViewData["Title"] = "SSS Yönetimi";
    Layout = "~/Views/Admin/_AdminLayout.cshtml";
    int count = 0;
}

<style>
    /* Tablo Genel Yapısı */
    .faq-table-card {
        border: none;
        border-radius: 15px;
    }

    /* Soru Metni Stilize */
    .faq-question {
        font-weight: 700;
        color: #2d3748;
        display: block;
        max-width: 250px;
        white-space: normal; /* Sorular genelde çok uzun olmaz, 2. satıra geçebilir */
        line-height: 1.4;
    }

    /* Cevap Kısmı Sınırlama (Tabloyu Bozmaz) */
    .faq-answer-truncate {
        display: -webkit-box;
        -webkit-line-clamp: 2; /* En fazla 2 satır göster */
        -webkit-box-orient: vertical;
        overflow: hidden;
        max-width: 450px;
        font-size: 0.875rem;
        color: #718096;
        line-height: 1.6;
        cursor: help; /* Bilgi verildiğini hissettirir */
    }

    /* Satır Hover Efekti */
    .table-faq tbody tr {
        transition: background-color 0.2s;
    }

        .table-faq tbody tr:hover {
            background-color: #f8fafc !important;
        }

    /* Badge Stilinde Sıra No */
    .count-badge {
        background: #edf2f7;
        color: #4a5568;
        width: 30px;
        height: 30px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 8px;
        font-size: 0.8rem;
        font-weight: 800;
    }

    /* İşlem Butonları */
    .btn-faq-action {
        padding: 7px 15px;
        border-radius: 10px;
        font-weight: 600;
        font-size: 0.8rem;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        border: none;
        transition: all 0.2s;
    }

    .btn-edit-faq {
        background: #fffbeb;
        color: #d97706;
    }

        .btn-edit-faq:hover {
            background: #fef3c7;
            color: #b45309;
            text-decoration: none;
        }

    .btn-delete-faq {
        background: #fff5f5;
        color: #e53e3e;
    }

        .btn-delete-faq:hover {
            background: #fee2e2;
            color: #c53030;
        }

</style>

<div class="row">
    <div class="col-12 grid-margin">
        <div class="card faq-table-card shadow-sm">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div>
                        <h4 class="card-title mb-1" style="font-weight: 800;">Sıkça Sorulan Sorular (SSS)</h4>
                        <p class="text-muted small mb-0">Yardım merkezindeki soruları ve cevapları buradan güncelleyebilirsiniz.</p>
                    </div>
                    <a href="/SSS/CreateSSS" class="btn btn-primary btn-rounded px-4 shadow-sm">
                        <i class="mdi mdi-plus-circle-outline mr-1"></i> Yeni Soru Ekle
                    </a>
                </div>

                @if (Model == null || !Model.Any())
                {
                    <div class="alert alert-info border-0 shadow-sm d-flex align-items-center" style="border-radius: 12px;">
                        <i class="mdi mdi-information-outline mr-3" style="font-size: 24px;"></i>
                        <div>
                            <b>Henüz veri yok!</b><br>
                            Müşterilerinizin merak ettiği soruları ekleyerek başlayın.
                        </div>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-faq align-middle">
                            <thead class="bg-light">
                                <tr>
                                    <th style="width: 50px;" class="pl-4">#</th>
                                    <th style="width: 30%;">Soru / Başlık</th>
                                    <th style="width: 45%;">Cevap / Açıklama</th>
                                    <th class="text-right pr-4">İşlemler</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    count++;
                                    <tr>
                                        <td class="pl-4">
                                            <div class="count-badge">@count</div>
                                        </td>
                                        <td>
                                            <span class="faq-question">@item.Title</span>
                                        </td>
                                        <td>
                                            <div class="faq-answer-truncate" title="@item.Description">
                                                @item.Description
                                            </div>
                                        </td>
                                        <td class="text-right pr-4">
                                            <div class="d-flex justify-content-end">
                                                <a href="/SSS/UpdateSSS/@item.SSSId" class="btn-faq-action btn-edit-faq mr-2">
                                                    <i class="mdi mdi-pencil-outline"></i> Güncelle
                                                </a>
                                                <button type="button" onclick="deleteConfirm('@item.SSSId')" class="btn-faq-action btn-delete-faq">
                                                    <i class="mdi mdi-trash-can-outline"></i> Sil
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    function deleteConfirm(id) {
        Swal.fire({
            title: 'Soru Silinsin mi?',
            text: "Bu içeriği sildiğinizde web sitesindeki SSS bölümünden de kaldırılacaktır.",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#e53e3e',
            cancelButtonColor: '#718096',
            confirmButtonText: 'Evet, Sil',
            cancelButtonText: 'Vazgeç',
            reverseButtons: true
        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = "/SSS/DeleteSSS/" + id;
            }
        })
    }
</script>